{
  "name": "imed-hr-davomat-bot",
  "version": "0.1.0",
  "description": "iMed Team HR / davomat / maosh Telegram boti (grammY + Supabase)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "gen:types": "supabase gen types typescript --project-id qechpuaeccynfvfihdrk > src/db/types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
